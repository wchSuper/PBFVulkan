#version 450
#extension GL_ARB_shading_language_include : require
#include "mpm2common.h"

layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;

void main() {
    uint id = gl_GlobalInvocationID.x;

    if (id < cellCount) {
        cells[id].mass = 0;
        cells[id].vx = 0;
        cells[id].vy = 0;
        cells[id].vz = 0;
    }
}
